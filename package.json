    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "server": "nodemon server.js",
        "clientstart": "npm start --prefix client",
        "clientbuild": "npm build --prefix client",
        "dev": "concurrently \"npm run server\" \"npm run clientstart\"",
        "startapp": "concurrently \"npm run server\" \"npm run clientstart\"",
        "buildapp": "concurrently \"npm run server\" \"npm run clientbuild\"",
        "start": "node server.js",
        "heroku postbuild": "NPM_CONFIG_PRODUCTION=false npm install -prefix client && npm run build --prefix client",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d build",
        "app-start-dev": "npm run client-start-dev --prefix client",
        "start-dev": "concurrently \"npm run server\" \"npm run app-start-dev\"",
        "app-build-dev": "npm run client-build-dev --prefix client",
        "build-dev": "concurrently \"npm run server\" \"npm run app-build-dev\"",
        "app-start-prod": "npm run client-start-prod --prefix client",
        "start-prod": "concurrently \"npm run server\" \"npm run app-start-prod\"",
        "app-build-prod": "npm run client-build-prod --prefix client",
        "build-prod": "concurrently \"npm run server\" \"npm run app-build-prod\""
